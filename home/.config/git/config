[init]
	defaultBranch = main
[pull]
	rebase = false
[user]
	name = Jorge Mederos
	email = 46798594+jmederosalvarado@users.noreply.github.com
	signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIOjJUdBorQUi19pxojdhcXEWI4fQg4dZ5PM9lZ4XEeKd
[alias]
    co = checkout
    ci = commit
    st = status
    br = branch
    wt = worktree
    hist = log --pretty=format:'%h %ad | %s%d [%an]' --graph --date=short
    type = cat-file -t
    dump = cat-file -p
    bare = "!sh $HOME/.dots/scripts/git-bare.sh"
[diff]
	external = difft
[merge]
	conflictStyle = diff3
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
[gpg]
	format = ssh
[gpg "ssh"]
	program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
	gpgsign = true
[push]
	autoSetupRemote = true
[core]
	attributesFile = ~/.config/git/attributes
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
